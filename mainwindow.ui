<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>900</width><height>640</height></rect>
  </property>
  <property name="windowTitle">
   <string>个人学业与简历管理系统</string>
  </property>
  <widget class="QWidget" name="centralWidget">
   <layout class="QVBoxLayout" name="rootLayout">
    <item>
     <widget class="QTabWidget" name="tabWidget">
      <property name="currentIndex"><number>0</number></property>

      <!-- ########## Tab 0: 学业管理 ########## -->
      <widget class="QWidget" name="tabAcademic">
       <attribute name="title"><string>学业管理</string></attribute>
       <layout class="QVBoxLayout" name="academicLayout">
        <item>
         <widget class="QGroupBox" name="grpCourseInput">
          <property name="title"><string>录入课程</string></property>
          <layout class="QHBoxLayout" name="courseInputLayout">
           <item><widget class="QLabel" name="lblName"><property name="text"><string>课程名称</string></property></widget></item>
           <item><widget class="QLineEdit" name="edit_course_name"><property name="placeholderText"><string>如：高等数学</string></property></widget></item>
           <item><widget class="QLabel" name="lblCredit"><property name="text"><string>学分</string></property></widget></item>
           <item><widget class="QLineEdit" name="edit_course_credit"><property name="placeholderText"><string>如：4.0</string></property></widget></item>
           <item><widget class="QLabel" name="lblScore"><property name="text"><string>成绩(0-100)</string></property></widget></item>
           <item><widget class="QLineEdit" name="edit_course_score"><property name="placeholderText"><string>如：85</string></property></widget></item>
           <item><widget class="QPushButton" name="btn_calc_gpa">
            <property name="styleSheet"><string>QPushButton { font-weight: bold; color: #c0392b; }</string></property>
            <property name="text"><string>添加并计算 GPA</string></property>
           </widget></item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QTableWidget" name="twCourses">
          <property name="editTriggers"><set>QAbstractItemView::NoEditTriggers</set></property>
          <property name="selectionBehavior"><enum>QAbstractItemView::SelectRows</enum></property>
          <attribute name="horizontalHeaderStretchLastSection"><bool>true</bool></attribute>
          <column><property name="text"><string>课程名称</string></property></column>
          <column><property name="text"><string>学分</string></property></column>
          <column><property name="text"><string>成绩</string></property></column>
         </widget>
        </item>
        <item>
         <layout class="QHBoxLayout" name="courseBtnRow">
          <item><widget class="QPushButton" name="btnRemoveCourse"><property name="text"><string>删除选中课程</string></property></widget></item>
          <item><spacer name="hSpacerCourse"><property name="orientation"><enum>Qt::Horizontal</enum></property></spacer></item>
         </layout>
        </item>
        <item>
         <widget class="QLabel" name="label_gpa_result">
          <property name="styleSheet"><string>font-size: 18px; font-weight: bold; color: #2a6496; padding: 8px;</string></property>
          <property name="text"><string>当前 GPA：--</string></property>
         </widget>
        </item>
       </layout>
      </widget>

      <!-- ########## Tab 1: 履历素材库 ########## -->
      <widget class="QWidget" name="tabExperience">
       <attribute name="title"><string>履历素材库</string></attribute>
       <layout class="QVBoxLayout" name="expLayout">
        <item>
         <widget class="QGroupBox" name="grpExpInput">
          <property name="title"><string>录入经历</string></property>
          <layout class="QVBoxLayout" name="expInputLayout">
           <item>
            <layout class="QHBoxLayout" name="expRow1">
             <item><widget class="QLabel" name="lblExpType"><property name="text"><string>类型</string></property></widget></item>
             <item><widget class="QComboBox" name="cbExpType">
              <item><property name="text"><string>实习经历</string></property></item>
              <item><property name="text"><string>项目经历</string></property></item>
              <item><property name="text"><string>校园经历</string></property></item>
              <item><property name="text"><string>其他</string></property></item>
             </widget></item>
             <item><widget class="QLabel" name="lblExpTitle"><property name="text"><string>标题</string></property></widget></item>
             <item><widget class="QLineEdit" name="leExpTitle"><property name="placeholderText"><string>如：会计实习生</string></property></widget></item>
             <item><widget class="QLabel" name="lblExpOrg"><property name="text"><string>机构</string></property></widget></item>
             <item><widget class="QLineEdit" name="leExpOrg"><property name="placeholderText"><string>如：XX公司</string></property></widget></item>
            </layout>
           </item>
           <item>
            <layout class="QHBoxLayout" name="expRow2">
             <item><widget class="QLabel" name="lblStart"><property name="text"><string>开始(YYYY.MM)</string></property></widget></item>
             <item><widget class="QLineEdit" name="edit_start_date"><property name="placeholderText"><string>2024.02</string></property></widget></item>
             <item><widget class="QLabel" name="lblEnd"><property name="text"><string>结束(YYYY.MM)</string></property></widget></item>
             <item><widget class="QLineEdit" name="edit_end_date"><property name="placeholderText"><string>2024.03</string></property></widget></item>
             <item><spacer name="hSpacerExp"><property name="orientation"><enum>Qt::Horizontal</enum></property></spacer></item>
             <item><widget class="QPushButton" name="btnAddExp"><property name="text"><string>添加经历</string></property></widget></item>
            </layout>
           </item>
           <item>
            <layout class="QHBoxLayout" name="expRow3">
             <item><widget class="QLabel" name="lblExpDesc"><property name="text"><string>描述</string></property></widget></item>
             <item><widget class="QTextEdit" name="teExpDesc"><property name="maximumHeight"><number>80</number></property><property name="placeholderText"><string>简要描述这段经历...</string></property></widget></item>
            </layout>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QTableWidget" name="twExperiences">
          <property name="editTriggers"><set>QAbstractItemView::NoEditTriggers</set></property>
          <property name="selectionBehavior"><enum>QAbstractItemView::SelectRows</enum></property>
          <attribute name="horizontalHeaderStretchLastSection"><bool>true</bool></attribute>
          <column><property name="text"><string>类型</string></property></column>
          <column><property name="text"><string>标题</string></property></column>
          <column><property name="text"><string>机构</string></property></column>
          <column><property name="text"><string>时间</string></property></column>
         </widget>
        </item>
        <item>
         <widget class="QPushButton" name="btnRemoveExp">
          <property name="text"><string>删除选中经历</string></property>
         </widget>
        </item>
       </layout>
      </widget>

      <!-- ########## Tab 2: 导出简历 ########## -->
      <widget class="QWidget" name="tabExport">
       <attribute name="title"><string>导出简历</string></attribute>
       <layout class="QVBoxLayout" name="exportLayout">

        <item>
         <widget class="QGroupBox" name="grpPersonal">
          <property name="title"><string>个人信息</string></property>
          <layout class="QVBoxLayout" name="personalLayout">
           <item>
            <layout class="QHBoxLayout" name="rowName">
             <item><widget class="QLabel" name="lblName2"><property name="text"><string>姓名</string></property><property name="minimumSize"><size><width>70</width><height>0</height></size></property></widget></item>
             <item><widget class="QLineEdit" name="edit_full_name"><property name="placeholderText"><string>请输入姓名（必填）</string></property></widget></item>
            </layout>
           </item>
           <item>
            <layout class="QHBoxLayout" name="rowContact">
             <item><widget class="QLabel" name="lblContact2"><property name="text"><string>联系方式</string></property><property name="minimumSize"><size><width>70</width><height>0</height></size></property></widget></item>
             <item><widget class="QLineEdit" name="edit_contact"><property name="placeholderText"><string>电话 / 邮箱</string></property></widget></item>
            </layout>
           </item>
           <item>
            <layout class="QHBoxLayout" name="rowTarget">
             <item><widget class="QLabel" name="lblTarget"><property name="text"><string>求职意向</string></property><property name="minimumSize"><size><width>70</width><height>0</height></size></property></widget></item>
             <item><widget class="QLineEdit" name="edit_target_job"><property name="placeholderText"><string>如：软件开发工程师</string></property></widget></item>
            </layout>
           </item>
          </layout>
         </widget>
        </item>

        <item>
         <widget class="QGroupBox" name="grpSkills">
          <property name="title"><string>技能 / 证书</string></property>
          <layout class="QVBoxLayout" name="skillsLayout">
           <item><widget class="QTextEdit" name="edit_skills"><property name="maximumHeight"><number>120</number></property><property name="placeholderText"><string>如：CET-6、计算机二级、熟练掌握 C++/Qt...</string></property></widget></item>
          </layout>
         </widget>
        </item>

        <item>
         <widget class="QLabel" name="lblSummary">
          <property name="styleSheet"><string>font-size: 14px; color: #555; padding: 8px;</string></property>
          <property name="text"><string>已录入 0 门课程 | 0 段经历 | GPA：--</string></property>
         </widget>
        </item>

        <item>
         <widget class="QPushButton" name="btn_export_pdf">
          <property name="minimumHeight"><number>40</number></property>
          <property name="styleSheet"><string>QPushButton { font-size: 16px; font-weight: bold; background-color: #2a6496; color: white; border-radius: 4px; } QPushButton:hover { background-color: #1d4f7a; }</string></property>
          <property name="text"><string>一键导出 PDF 简历</string></property>
         </widget>
        </item>

        <item>
         <widget class="QLabel" name="label_status_msg">
          <property name="styleSheet"><string>font-size: 13px; color: #666; padding: 4px;</string></property>
          <property name="text"><string>就绪</string></property>
         </widget>
        </item>

       </layout>
      </widget>

     </widget>
    </item>
   </layout>
  </widget>
  <widget class="QStatusBar" name="statusBar"/>
 </widget>
 <resources/>
 <connections/>
